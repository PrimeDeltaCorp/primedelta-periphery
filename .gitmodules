[submodule "lib/forge-std"]
	path = lib/forge-std
	url = https://github.com/foundry-rs/forge-std.git
[submodule "lib/dclex-blockchain"]
	path = lib/dclex-blockchain
	url = https://github.com/PrimeDeltaCorp/blockchain.git
	branch = main
[submodule "lib/dclex-protocol"]
	path = lib/dclex-protocol
	url = https://github.com/PrimeDeltaCorp/primedelta-protocol.git
	branch = main
[submodule "lib/openzeppelin-contracts"]
	path = lib/openzeppelin-contracts
	url = https://github.com/OpenZeppelin/openzeppelin-contracts.git
[submodule "lib/v3-core"]
	path = lib/v3-core
	url = https://github.com/dclex-platform/v3-core.git
	branch = 0.8
[submodule "lib/v3-periphery"]
	path = lib/v3-periphery
	url = git@github-primedelta:PrimeDeltaCorp/v3-periphery.git
	branch = 0.8
[submodule "lib/base64"]
	path = lib/base64
	url = https://github.com/Brechtpd/base64.git
